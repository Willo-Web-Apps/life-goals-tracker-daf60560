---
import Base from '../layouts/Base.astro';
---
<Base
  title="Flowo — Get more out of life"
  description="Flowo is the personal to-do tracker that helps you stop managing tasks and start living intentionally. Capture everything, focus on what matters, and see yourself grow."
>

  <!-- ── 1. HERO ─────────────────────────────────────────────────────────── -->
  <section class="relative min-h-[88vh] flex items-center overflow-hidden" style="background-color: #FDFAF6;">
    <!-- Layered gradient atmosphere -->
    <div class="absolute inset-0" style="background:
      radial-gradient(ellipse 70% 65% at 8% 35%, rgba(13,115,119,0.07), transparent 55%),
      radial-gradient(ellipse 55% 75% at 92% 15%, rgba(255,107,107,0.07), transparent 50%),
      radial-gradient(ellipse 60% 50% at 55% 95%, rgba(237,212,184,0.5), transparent 55%),
      linear-gradient(160deg, #FDFAF6 0%, #F5E6D3 100%);">
    </div>
    <!-- Dot texture -->
    <div class="absolute inset-0 opacity-[0.03]"
      style="background-image: radial-gradient(circle, #1A1A2E 1px, transparent 1px); background-size: 30px 30px;">
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 lg:py-36">
      <div class="max-w-4xl">
        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full text-sm font-semibold mb-8 animate-slide-up"
             style="background-color: rgba(13,115,119,0.1); color: #0D7377;">
          <span class="w-1.5 h-1.5 rounded-full inline-block" style="background-color: #0D7377;"></span>
          Your life, by design
        </div>

        <!-- H1 -->
        <h1 class="text-5xl md:text-6xl lg:text-[80px] font-extrabold tracking-tight leading-[1.04] animate-slide-up delay-100"
            style="color: #111120; font-family: 'Plus Jakarta Sans', sans-serif; letter-spacing: -0.03em;">
          Stop managing tasks.<br>
          <span style="color: #0D7377;">Start living better.</span>
        </h1>

        <!-- Subheadline -->
        <p class="mt-6 text-lg md:text-xl max-w-2xl leading-relaxed animate-slide-up delay-200"
           style="color: rgba(26,26,46,0.65); font-family: 'Plus Jakarta Sans', sans-serif;">
          Flowo turns your endless to-do list into a clear daily practice — so you finish each day feeling accomplished, not buried.
        </p>

        <!-- CTAs -->
        <div class="mt-10 flex flex-col sm:flex-row gap-3 animate-slide-up delay-300">
          <a href="#waitlist"
             class="inline-flex items-center justify-center gap-2 px-7 py-3.5 font-semibold rounded-xl transition-opacity hover:opacity-90 text-base"
             style="background-color: #FF6B6B; color: #ffffff; box-shadow: 0 8px 24px rgba(255,107,107,0.30);">
            Join the waitlist free
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a href="#how-it-works"
             class="inline-flex items-center justify-center gap-2 px-7 py-3.5 font-semibold rounded-xl border transition-all hover:border-brand-400 text-base"
             style="background-color: rgba(255,255,255,0.7); color: #1A1A2E; border-color: #EDD4B8;">
            See how it works
          </a>
        </div>
        <p class="mt-3 text-sm animate-slide-up delay-400" style="color: rgba(26,26,46,0.38);">
          Free forever tier available. No credit card required.
        </p>
      </div>
    </div>
  </section>

  <!-- ── 2. STATS BAR ──────────────────────────────────────────────────────── -->
  <section style="border-top: 1px solid #EDD4B8; border-bottom: 1px solid #EDD4B8; background-color: rgba(255,255,255,0.7);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-7">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-0 md:divide-x" style="--tw-divide-opacity: 1; divide-color: #EDD4B8;">
        <div class="text-center md:px-8">
          <p class="text-3xl font-extrabold tabular-nums" style="color: #111120; letter-spacing: -0.02em;">47k+</p>
          <p class="mt-1 text-sm" style="color: rgba(26,26,46,0.55);">tasks done today</p>
        </div>
        <div class="text-center md:px-8">
          <p class="text-3xl font-extrabold tabular-nums" style="color: #111120; letter-spacing: -0.02em;">4.9★</p>
          <p class="mt-1 text-sm" style="color: rgba(26,26,46,0.55);">app store rating</p>
        </div>
        <div class="text-center md:px-8">
          <p class="text-3xl font-extrabold tabular-nums" style="color: #111120; letter-spacing: -0.02em;">3 min</p>
          <p class="mt-1 text-sm" style="color: rgba(26,26,46,0.55);">to your first win</p>
        </div>
        <div class="text-center md:px-8">
          <p class="text-3xl font-extrabold tabular-nums" style="color: #111120; letter-spacing: -0.02em;">89%</p>
          <p class="mt-1 text-sm" style="color: rgba(26,26,46,0.55);">hit goals faster</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 3. FEATURES ───────────────────────────────────────────────────────── -->
  <section id="features" class="py-20 md:py-28 lg:py-32" style="background-color: #FFFFFF;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-widest mb-3" style="color: #0D7377;">Why Flowo</p>
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight leading-tight" style="color: #111120; letter-spacing: -0.025em;">
          Built for humans,<br>not project managers.
        </h2>
        <p class="mt-4 text-lg leading-relaxed" style="color: rgba(26,26,46,0.60);">
          Most task apps make you feel busier. Flowo is designed to make you feel lighter — by showing you what to do now and celebrating what you've done.
        </p>
      </div>

      <!-- Cards grid -->
      <div class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-5">
        <!-- Card 1 -->
        <div class="p-7 rounded-2xl border transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5 animate-slide-up delay-100"
             style="background-color: #FDFAF6; border-color: #EDD4B8;">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5"
               style="background-color: rgba(13,115,119,0.1);">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" style="color: #0D7377;">
              <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold" style="color: #111120; letter-spacing: -0.01em;">Instant capture</h3>
          <p class="mt-2 leading-relaxed" style="color: rgba(26,26,46,0.60); font-size: 0.9375rem;">
            Dump any thought in under two seconds — typed, spoken, or shared from any app. Your head stays clear, your list stays complete.
          </p>
        </div>

        <!-- Card 2 -->
        <div class="p-7 rounded-2xl border transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5 animate-slide-up delay-200"
             style="background-color: #FDFAF6; border-color: #EDD4B8;">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5"
               style="background-color: rgba(13,115,119,0.1);">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" style="color: #0D7377;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold" style="color: #111120; letter-spacing: -0.01em;">Daily Focus</h3>
          <p class="mt-2 leading-relaxed" style="color: rgba(26,26,46,0.60); font-size: 0.9375rem;">
            Each morning Flowo surfaces your 3–5 most important tasks. No overwhelm, no paralysis — just a clear, winnable day.
          </p>
        </div>

        <!-- Card 3 -->
        <div class="p-7 rounded-2xl border transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5 animate-slide-up delay-300"
             style="background-color: #FDFAF6; border-color: #EDD4B8;">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5"
               style="background-color: rgba(13,115,119,0.1);">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" style="color: #0D7377;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" />
            </svg>
          </div>
          <h3 class="text-xl font-bold" style="color: #111120; letter-spacing: -0.01em;">Life Score</h3>
          <p class="mt-2 leading-relaxed" style="color: rgba(26,26,46,0.60); font-size: 0.9375rem;">
            See which life areas — work, health, relationships, creativity — you're investing in. Balance isn't a feeling, it's a number.
          </p>
        </div>
      </div>

      <!-- Second row -->
      <div class="mt-5 grid grid-cols-1 md:grid-cols-2 gap-5">
        <div class="p-7 rounded-2xl border transition-all duration-200 hover:shadow-lg animate-slide-up delay-100"
             style="background: linear-gradient(135deg, rgba(13,115,119,0.06) 0%, rgba(13,115,119,0.02) 100%); border-color: rgba(13,115,119,0.2);">
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center shrink-0" style="background-color: rgba(13,115,119,0.15);">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" style="color: #0D7377;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold" style="color: #111120; letter-spacing: -0.01em;">Recurring rituals</h3>
              <p class="mt-2 leading-relaxed" style="color: rgba(26,26,46,0.60); font-size: 0.9375rem;">
                Morning routines, weekly reviews, monthly check-ins. Automate the habits that compound. Set once, benefit forever.
              </p>
            </div>
          </div>
        </div>

        <div class="p-7 rounded-2xl border transition-all duration-200 hover:shadow-lg animate-slide-up delay-200"
             style="background: linear-gradient(135deg, rgba(255,107,107,0.05) 0%, rgba(255,107,107,0.01) 100%); border-color: rgba(255,107,107,0.2);">
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center shrink-0" style="background-color: rgba(255,107,107,0.12);">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" style="color: #FF6B6B;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold" style="color: #111120; letter-spacing: -0.01em;">Evening review</h3>
              <p class="mt-2 leading-relaxed" style="color: rgba(26,26,46,0.60); font-size: 0.9375rem;">
                A 2-minute end-of-day ritual that celebrates wins, rolls over incomplete tasks, and primes tomorrow before you close the laptop.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 4. HOW IT WORKS ────────────────────────────────────────────────────── -->
  <section id="how-it-works" class="py-20 md:py-28 lg:py-32" style="background-color: #FDFAF6;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-sm font-semibold uppercase tracking-widest mb-3" style="color: #0D7377;">How it works</p>
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight leading-tight" style="color: #111120; letter-spacing: -0.025em;">
          From scattered to sorted in three steps
        </h2>
        <p class="mt-4 text-lg leading-relaxed" style="color: rgba(26,26,46,0.60);">
          Getting started takes less than three minutes — and you'll feel the difference on day one.
        </p>
      </div>

      <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8 relative">
        <!-- Connector (desktop) -->
        <div class="hidden md:block absolute top-10 left-[calc(16.67%+2rem)] right-[calc(16.67%+2rem)] h-px"
             style="background: linear-gradient(to right, #99D4D6, #0D7377, #99D4D6);"></div>

        <!-- Step 1 -->
        <div class="text-center animate-slide-up delay-100">
          <div class="w-20 h-20 rounded-full flex items-center justify-center text-3xl font-extrabold text-white mx-auto"
               style="background-color: #0D7377; box-shadow: 0 8px 24px rgba(13,115,119,0.30); letter-spacing: -0.02em;">
            1
          </div>
          <h3 class="mt-6 text-xl font-bold" style="color: #111120; letter-spacing: -0.01em;">Capture everything</h3>
          <p class="mt-3 leading-relaxed" style="color: rgba(26,26,46,0.60); font-size: 0.9375rem;">
            Dump every task, idea, and responsibility into Flowo. Don't organize yet — just get it out of your head.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="text-center animate-slide-up delay-200">
          <div class="w-20 h-20 rounded-full flex items-center justify-center text-3xl font-extrabold text-white mx-auto"
               style="background-color: #0D7377; box-shadow: 0 8px 24px rgba(13,115,119,0.30); letter-spacing: -0.02em;">
            2
          </div>
          <h3 class="mt-6 text-xl font-bold" style="color: #111120; letter-spacing: -0.01em;">Focus your day</h3>
          <p class="mt-3 leading-relaxed" style="color: rgba(26,26,46,0.60); font-size: 0.9375rem;">
            Flowo suggests your top 3–5 for the day. Takes 2 minutes to approve. Zero decision fatigue, total clarity.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="text-center animate-slide-up delay-300">
          <div class="w-20 h-20 rounded-full flex items-center justify-center text-3xl font-extrabold text-white mx-auto"
               style="background-color: #0D7377; box-shadow: 0 8px 24px rgba(13,115,119,0.30); letter-spacing: -0.02em;">
            3
          </div>
          <h3 class="mt-6 text-xl font-bold" style="color: #111120; letter-spacing: -0.01em;">Watch yourself grow</h3>
          <p class="mt-3 leading-relaxed" style="color: rgba(26,26,46,0.60); font-size: 0.9375rem;">
            Weekly insights show what you accomplished and which life areas you're investing in. Progress compounds.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 5. SHOWCASE — alternating panels ──────────────────────────────────── -->
  <section class="py-20 md:py-28" style="background-color: #FFFFFF;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-20 md:space-y-28">

      <!-- Panel A: text left, visual right -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-widest mb-3" style="color: #0D7377;">Daily Focus</p>
          <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight leading-tight" style="color: #111120; letter-spacing: -0.025em;">
            Stop staring at 47 tasks.<br>Start with the right 3.
          </h2>
          <p class="mt-5 text-lg leading-relaxed" style="color: rgba(26,26,46,0.60);">
            Flowo's Focus Mode distills your whole list into a daily shortlist — the tasks that will actually move your life forward. You spend your energy where it counts, not where it shouts loudest.
          </p>
          <ul class="mt-6 space-y-3">
            {['Smart priority suggestions based on your goals', 'Overdue items resurface automatically', 'Done by noon more often than you think'].map(item => (
              <li class="flex items-center gap-3" style="color: rgba(26,26,46,0.70); font-size: 0.9375rem;">
                <span class="w-5 h-5 rounded-full flex items-center justify-center shrink-0" style="background-color: rgba(13,115,119,0.12);">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" style="color: #0D7377;"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 0 1 0 1.414l-8 8a1 1 0 0 1-1.414 0l-4-4a1 1 0 0 1 1.414-1.414L8 12.586l7.293-7.293a1 1 0 0 1 1.414 0Z" clip-rule="evenodd"/></svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <!-- Visual — mock focus UI -->
        <div class="relative">
          <div class="rounded-2xl overflow-hidden border shadow-2xl" style="border-color: #EDD4B8; background: linear-gradient(140deg, #FDFAF6 0%, #F5E6D3 100%); box-shadow: 0 20px 60px rgba(13,115,119,0.12);">
            <div class="p-6 md:p-8">
              <div class="flex items-center justify-between mb-5">
                <p class="text-xs font-bold uppercase tracking-widest" style="color: #0D7377;">Today's focus · Tuesday</p>
                <span class="text-xs px-2.5 py-1 rounded-full font-semibold" style="background-color: rgba(13,115,119,0.1); color: #0D7377;">2 / 3 done</span>
              </div>
              <div class="space-y-2.5">
                <div class="flex items-center gap-3 p-3.5 rounded-xl shadow-sm" style="background-color: #FFFFFF; border: 1px solid #EDD4B8;">
                  <div class="w-5 h-5 rounded-full flex items-center justify-center shrink-0" style="background-color: #0D7377; border: 2px solid #0D7377;">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 0 1 0 1.414l-8 8a1 1 0 0 1-1.414 0l-4-4a1 1 0 0 1 1.414-1.414L8 12.586l7.293-7.293a1 1 0 0 1 1.414 0Z" clip-rule="evenodd"/></svg>
                  </div>
                  <span class="text-sm line-through flex-1" style="color: rgba(26,26,46,0.35);">Morning run — 30 min</span>
                  <span class="text-xs font-semibold" style="color: #0D7377;">Done ✓</span>
                </div>
                <div class="flex items-center gap-3 p-3.5 rounded-xl shadow-sm" style="background-color: #FFFFFF; border: 1px solid #EDD4B8;">
                  <div class="w-5 h-5 rounded-full flex items-center justify-center shrink-0" style="background-color: #0D7377; border: 2px solid #0D7377;">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 0 1 0 1.414l-8 8a1 1 0 0 1-1.414 0l-4-4a1 1 0 0 1 1.414-1.414L8 12.586l7.293-7.293a1 1 0 0 1 1.414 0Z" clip-rule="evenodd"/></svg>
                  </div>
                  <span class="text-sm line-through flex-1" style="color: rgba(26,26,46,0.35);">Prep slides for client call</span>
                  <span class="text-xs font-semibold" style="color: #0D7377;">Done ✓</span>
                </div>
                <div class="flex items-center gap-3 p-3.5 rounded-xl shadow-sm" style="background-color: #FFFFFF; border: 2px solid #0D7377;">
                  <div class="w-5 h-5 rounded-full border-2 shrink-0" style="border-color: #0D7377;"></div>
                  <span class="text-sm font-semibold flex-1" style="color: #111120;">Write proposal for Emily</span>
                  <span class="text-xs px-2 py-0.5 rounded-full font-semibold" style="background-color: rgba(255,107,107,0.1); color: #FF6B6B;">High</span>
                </div>
                <div class="p-3.5 rounded-xl opacity-50" style="border: 1px dashed #EDD4B8;">
                  <span class="text-sm" style="color: rgba(26,26,46,0.40);">+ 11 more in inbox</span>
                </div>
              </div>
              <!-- Progress bar -->
              <div class="mt-5 flex items-center gap-3">
                <div class="h-1.5 flex-1 rounded-full overflow-hidden" style="background-color: #EDD4B8;">
                  <div class="h-full rounded-full" style="width: 66%; background-color: #0D7377;"></div>
                </div>
                <span class="text-xs font-semibold" style="color: #0D7377;">66%</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Panel B: visual left, text right -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Visual — Life Score -->
        <div class="order-2 md:order-1">
          <div class="rounded-2xl overflow-hidden border shadow-2xl" style="background-color: #111120; border-color: rgba(255,255,255,0.06); box-shadow: 0 20px 60px rgba(0,0,0,0.2);">
            <div class="p-6 md:p-8">
              <p class="text-xs font-bold uppercase tracking-widest mb-5" style="color: #55B8BB;">Your life score · This week</p>
              <div class="space-y-4">
                <div>
                  <div class="flex justify-between items-center mb-1.5">
                    <span class="text-sm" style="color: rgba(255,255,255,0.65);">Health & Body</span>
                    <span class="text-sm font-bold tabular-nums" style="color: #ffffff;">82%</span>
                  </div>
                  <div class="h-2 rounded-full overflow-hidden" style="background-color: rgba(255,255,255,0.08);">
                    <div class="h-full rounded-full" style="width: 82%; background-color: #0D7377;"></div>
                  </div>
                </div>
                <div>
                  <div class="flex justify-between items-center mb-1.5">
                    <span class="text-sm" style="color: rgba(255,255,255,0.65);">Deep Work</span>
                    <span class="text-sm font-bold tabular-nums" style="color: #ffffff;">71%</span>
                  </div>
                  <div class="h-2 rounded-full overflow-hidden" style="background-color: rgba(255,255,255,0.08);">
                    <div class="h-full rounded-full" style="width: 71%; background-color: #0D7377;"></div>
                  </div>
                </div>
